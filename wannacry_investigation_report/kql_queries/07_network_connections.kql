// 07_network_connections.kql
// Goal: Summarize outbound connections during the selected time window

DeviceNetworkEvents
| where DeviceName == "vm-final-lab-wo"
| where ActionType in ("ConnectionSuccess","ConnectionAttempt","NetworkConnectionInitiated","NetworkConnectionSuccess")
| summarize Connections=count(), FirstSeen=min(TimeGenerated), LastSeen=max(TimeGenerated) by RemoteIP, RemotePort, InitiatingProcessFileName
| sort by Connections desc
